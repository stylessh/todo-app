# Better Auth secret used to sign sessions/cookies. Keep this private.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# Public URL of the auth server.
BETTER_AUTH_URL=http://localhost:3000

# Port the auth server listens on.
PORT=3000

# Path to the SQLite database file.
DATABASE_PATH=./sqlite.db

# Comma-separated origins allowed to make authenticated requests (the Vite dev server).
TRUSTED_ORIGINS=http://localhost:5173

# --- Optional social providers ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
